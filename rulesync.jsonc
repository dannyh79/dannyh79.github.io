{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",
  "targets": ["claudecode", "codexcli", "antigravity-cli", "agentsmd", "agentsskills"],
  "features": ["rules", "ignore", "mcp", "commands", "subagents", "skills", "hooks"],
  "outputRoots": ["."],
  "delete": false,
  "verbose": false,
  "silent": false,
  "global": false,
  "simulateCommands": false,
  "simulateSubagents": false,
  "simulateSkills": false,
  "gitignoreTargetsOnly": true,
}
